@layout UI.MainLayout


<main class="flex-grow-1 d-flex align-items-center justify-content-center px-3" style="min-height: 75vh;">
    <!-- Khối thẻ Card chứa Form -->
    <div class="card-body p-4 p-md-5">
        <div id="register-container">
    <div class="card border border-light-subtle shadow-sm" style="max-width: 448px; width: 100%; border-radius: 4px;">
        <div class="card-body p-4 p-md-5">
            
            <!-- Tiêu đề -->
            <div class="text-center mb-4">
                <h2 class="font-work-sans fw-bold mb-1" style="color: #0b1c30;">THE ESSAY</h2>
                <p class="font-newsreader text-gray fs-5">Create your account</p>
            </div>

            <!-- Form Đăng ký tích hợp HTMX -->
            <form hx-post="/api/v1/auth/register" hx-target="closest main" hx-swap="outerHTML">
                
                <!-- Input: Email -->
                <div class="mb-3 text-start">
                    <label class="form-label font-work-sans fw-semibold" style="color: #0b1c30; font-size: 14px;">
                        Email address
                    </label>
                    <input type="email" 
                           name="Email" 
                           class="form-control" 
                           placeholder="name@example.com" 
                           style="border-radius: 2px; padding: 12px 16px;"
                           value="@submittedEmail"
                           required>
                    @if(errors.ContainsKey("Email")) {
                        <div class="form-text font-work-sans text-danger" style="font-size: 13px;">@errors["Email"]</div>
                    }
                </div>

                <!-- Input: Password -->
                <div class="mb-3 text-start">
                    <label class="form-label font-work-sans fw-semibold mb-0" style="color: #0b1c30; font-size: 14px;">
                        Password
                    </label>
                    <input type="password" 
                           name="Password" 
                           class="form-control mt-2" 
                           placeholder="At least 8 characters" 
                           minlength="8"
                           style="border-radius: 2px; padding: 12px 16px;"
                           required>
                    @if(errors.ContainsKey("Password")) {
                        <div class="form-text font-work-sans text-danger" style="font-size: 13px;">@errors["Password"]</div>
                    }
                </div>  

                <!-- Input: Confirm Password -->
                <div class="mb-4 text-start">
                    <label class="form-label font-work-sans fw-semibold mb-0" style="color: #0b1c30; font-size: 14px;">
                        Confirm password
                    </label>
                    <input type="password" 
                           name="ConfirmPassword" 
                           class="form-control mt-2" 
                           placeholder="Re-enter your password" 
                           minlength="8"
                           style="border-radius: 2px; padding: 12px 16px;"
                           required>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="btn btn-black w-100 py-2 mb-4 font-work-sans" style="font-size: 16px;">
                    Sign Up
                </button>
            </form>

            <!-- Footer Links -->
            <div class="text-center font-newsreader text-gray fs-6">
                Already have an account? 
                <!-- Lưu ý: Nếu App.razor đã có hx-boost="true" ở <body> thì không cần ghi lại ở đây -->
                <a href="/api/v1/auth/login" class="text-decoration-none font-work-sans" style="color: #0051d5;">Log in</a>
            </div>

        </div>
    </div>
        </div>
    </div>
</main>


@code{
    [Parameter]
    public Dictionary<string, string> errors {get; set;} = new();
    
    [Parameter]
    public string submittedEmail {get; set;} = "";
}