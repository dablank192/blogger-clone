<!-- File: RegisterSuccessView.razor -->

<div id="register-container" class="text-center py-4 fade-in">
    
    <!-- Icon Checkmark thành công của Bootstrap -->
    <div class="mb-4">
        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" fill="#198754" class="bi bi-check-circle-fill" viewBox="0 0 16 16">
            <path d="M16 8A8 8 0 1 1 0 8a8 8 0 0 1 16 0zm-3.97-3.03a.75.75 0 0 0-1.08.022L7.477 9.417 5.384 7.323a.75.75 0 0 0-1.06 1.06L6.97 11.03a.75.75 0 0 0 1.079-.02l3.992-4.99a.75.75 0 0 0-.01-1.05z"/>
        </svg>
    </div>

    <!-- Tiêu đề -->
    <h3 class="font-work-sans fw-bold mb-3" style="color: #0b1c30;">Registration Successful!</h3>
    
    <!-- Lời nhắn -->
    <p class="font-newsreader text-gray fs-5 mb-5 px-3" style="line-height: 1.5;">
        Welcome to THE ESSAY. Your account has been created successfully. You can now log in to start writing.
    </p>

    <!-- Nút bấm quay về Login -->
    <!-- Dùng hx-boost="true" (nếu chưa cài ở thẻ body) hoặc href bình thường -->
    <a href="/login" class="btn btn-black w-100 py-2 font-work-sans" style="font-size: 16px;">
        Go to Login
    </a>

</div>

<style>
    /* Thêm một hiệu ứng mờ dần nhẹ nhàng khi chuyển đổi Form -> Thông báo */
    .fade-in {
        animation: fadeIn 0.4s ease-in-out;
    }
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>