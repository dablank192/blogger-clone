@using blogger_clone.UI
@layout MainLayout

<main class="flex-grow-1 d-flex align-items-center justify-content-center px-3" style="min-height: 75vh;">
    <!-- Khối thẻ Card chứa Form -->
    <div class="card border border-light-subtle shadow-sm" style="max-width: 448px; width: 100%; border-radius: 4px;">
        <div class="card-body p-4 p-md-5">
            
            <!-- Tiêu đề -->
            <div class="text-center mb-4">
                <h2 class="font-work-sans fw-bold mb-1" style="color: #0b1c30;">THE ESSAY</h2>
                <p class="font-newsreader text-gray fs-5">Sign in to your account</p>
            </div>

            <!-- HTMX Form được cấu hình sẵn để gọi vào Minimal API của bạn -->
            <form hx-post="/api/v1/auth/login" hx-swap="outerHTML">
                
                <!-- Input: Username / Email -->
                <div class="mb-3 text-start">
                    <label class="form-label font-work-sans fw-semibold" style="color: #0b1c30; font-size: 14px;">
                        Username or Email
                    </label>
                    <input type="text" 
                           name="UsernameOrEmail" 
                           class="form-control" 
                           placeholder="Enter your username or email" 
                           style="border-radius: 2px; padding: 12px 16px;"
                           required>
                </div>

                <!-- Input: Password -->
                <div class="mb-4 text-start">
                    <div class="d-flex justify-content-between align-items-center">
                        <label class="form-label font-work-sans fw-semibold mb-0" style="color: #0b1c30; font-size: 14px;">
                            Password
                        </label>
                        <a href="/forgot-password" class="text-decoration-none font-work-sans" style="color: #0051d5; font-size: 14px;">
                            Forgot Password?
                        </a>
                    </div>
                    <input type="password" 
                           name="Password" 
                           class="form-control mt-2" 
                           placeholder="Enter your password" 
                           style="border-radius: 2px; padding: 12px 16px;"
                           required>
                </div>

                <!-- Submit Button (Sử dụng class .btn-black từ app.css) -->
                <button type="submit" class="btn btn-black w-100 py-2 mb-4 font-work-sans" style="font-size: 16px;">
                    Sign In
                </button>
            </form>

            <!-- Footer Links -->
            <div class="text-center font-newsreader text-gray fs-6">
                Don't have an account? 
                <a href="/signup" class="text-decoration-none font-work-sans" style="color: #0051d5;">Sign up</a>
            </div>

        </div>
    </div>
</main>