@using blogger_clone.UI
@layout MainLayout


<main class="flex-grow-1 d-flex align-items-center justify-content-center text-center px-3" style="min-height: 70vh;">
        <div style="max-width: 720px;">
            <!-- Headline -->
            <h1 class="font-work-sans fw-bold mb-4" style="font-size: 3rem; color: #0b1c30; line-height: 1.2;">
                Start writing and share your stories with the world.
            </h1>
            
            <!-- Sub-headline -->
            <p class="font-newsreader fs-5 mb-5 text-gray mx-auto" style="max-width: 680px; line-height: 1.6;">
                A minimalist platform designed for clarity, focus, and the pure joy of reading and writing. No distractions, just your words.
            </p>
            
            <!-- Call To Action -->
            <a href="/create" class="btn btn-light border px-4 py-2 font-newsreader shadow-sm" style="border-radius: 2px; color: #0b1c30; font-size: 1.1rem;">
                Start Writing
            </a>
        </div>
    </main>